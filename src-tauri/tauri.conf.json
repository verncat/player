{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "player",
  "version": "0.2.6",
  "identifier": "dev.verncat.player",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "player",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "android": {
      "minSdkVersion": 26
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxQzNCNTVGQTkwQjBEMkIKUldRckRRdXBYN1hEUWFiTlhFTG1Fcmk3WmwvT29HYXRpZytaVjBiS3hOb1RRZDVvaU9XSWtwSnIK",
      "endpoints": [
        "https://github.com/verncat/player/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
